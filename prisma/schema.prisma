generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  message   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  status    String
}
